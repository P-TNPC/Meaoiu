		"email": "TNPC@TNPC.space"
	},
	"homepage": "https://github.com/P-TNPC/Meaoiu#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/P-TNPC/Meaoiu.git"
	},
	"bugs": {
