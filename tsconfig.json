{
	"compilerOptions": {
		// 文件结构
		"rootDir": "./src",
		"outDir": "./dist",

		// 环境规范
		"module": "nodenext",
		"target": "esnext",
		"lib": ["esnext"],
		"types": ["node"],

		// 输出附加
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		// 类型严查
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		// 品质之选
		"noImplicitReturns": true,
		"noImplicitOverride": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noPropertyAccessFromIndexSignature": true,

		// 补充选项
		"strict": true,
		// "isolatedDeclarations": true,
		"isolatedModules": false, // 一些打包器需启用，仅 tsc 则无需
		"verbatimModuleSyntax": false, // 同上
		"preserveConstEnums": false, // 此为 false 时，上两项应同为 false
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": false
	}
}
