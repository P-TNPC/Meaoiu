{
	"compilerOptions": {
		// 文件结构
		"rootDir": "./src",
		"outDir": "./dist",

		// 环境规范
		"module": "nodenext",
		"target": "esnext",
		"lib": ["esnext"],
		"types": ["node"],

		// 输出附加
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		// 类型严查
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		// 品质之选
		"noImplicitReturns": true,
		"noImplicitOverride": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noPropertyAccessFromIndexSignature": true,

		// 补充选项
		"strict": true,
		"verbatimModuleSyntax": false, // 弊于常量枚举，禁
		"isolatedModules": false, // 弊于常量枚举，禁
		"preserveConstEnums": false, // 生成的用不上，禁
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": false
	}
}
